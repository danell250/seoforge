{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend/seoforge && pnpm run build",
  "outputDirectory": "frontend/seoforge/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "@vite_api_url"
  }
}
