# Backend Environment Variables
PORT=4000
NODE_ENV=development
GEMINI_API_KEY=your_gemini_api_key_here

# CORS - Frontend URL (for development)
FRONTEND_URL=http://localhost:5173
# Optional comma-separated override for multiple allowed frontend origins
# FRONTEND_URLS=http://localhost:5173,https://app.example.com

# Admin login bootstrap
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=ChangeMe123!
# Set to true once when you want the server to create the bootstrap admin record
AUTH_BOOTSTRAP_ADMIN=false

# Database (if needed)
# DATABASE_URL=

# Email (if needed)
# RESEND_API_KEY=
