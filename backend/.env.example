# Backend Environment Variables
PORT=4000
NODE_ENV=development
GEMINI_API_KEY=your_gemini_api_key_here

# CORS - Frontend URL (for development)
FRONTEND_URL=http://localhost:5173
# Optional comma-separated override for multiple allowed frontend origins
# FRONTEND_URLS=http://localhost:5173,https://app.example.com

# Admin login bootstrap
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=<set-a-long-random-password>
# Bootstrap accounts default to the Agency plan so all core features are available.
ADMIN_PLAN=agency
# Set to true once when you want the server to create the bootstrap admin record
AUTH_BOOTSTRAP_ADMIN=false
# Use "none" for cross-domain deployments (for example Vercel + Render).
# Switch this to "lax" only for same-origin local development if needed.
SESSION_COOKIE_SAMESITE=none
# Keep partitioned cookies enabled for cross-site frontend/backend deployments
SESSION_COOKIE_PARTITIONED=true

# Database (if needed)
# DATABASE_URL=

# Email (if needed)
# RESEND_API_KEY=
