{
  "name": "@workspace/frontend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev:seoforge": "pnpm --filter @workspace/seoforge run dev",
    "dev:mockup": "pnpm --filter @workspace/mockup-sandbox run dev",
